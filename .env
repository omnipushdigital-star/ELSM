# ─── DATABASE ───────────────────────────────────────────
POSTGRES_USER=elsm_user
POSTGRES_PASSWORD=elsm_pass
POSTGRES_DB=elsm_db
DATABASE_URL=postgresql+asyncpg://elsm_user:elsm_pass@db:5432/elsm_db

# ─── REDIS ──────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── SECURITY ───────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
TOTP_ISSUER=ELSM_Portal

# ─── MINIO (File Storage) ────────────────────────────────
MINIO_ROOT_USER=elsm_minio
MINIO_ROOT_PASSWORD=elsm_minio_pass
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=elsm-evidence
MINIO_SECURE=false

# ─── EMAIL ──────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAILS_FROM=noreply@elsm.in

# ─── SMS (Twilio) ────────────────────────────────────────
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# ─── APP ─────────────────────────────────────────────────
APP_NAME=ELSM Portal
APP_ENV=development
DEBUG=true
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000","https://elsm-cbic-dashboard.vercel.app"]

# ─── SLA ─────────────────────────────────────────────────
ESE_EUE_SLA_WORKING_DAYS=3
BATTERY_ALERT_THRESHOLD=25
UC_VERIFICATION_DAYS=3
